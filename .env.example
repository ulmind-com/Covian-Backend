# ------------------------------------------------------------------------------
# Premium FastAPI Backend Environment Variables Configuration Template
# Copy this file to '.env' and adjust the variables for your local setup.
# ------------------------------------------------------------------------------

# Application General
PROJECT_NAME="Premium FastAPI Backend"
ENVIRONMENT="development"
API_V1_STR="/api/v1"

# CORS Configurations
# Comma-separated list of allowed origins
BACKEND_CORS_ORIGINS="http://localhost:3000,http://localhost:8000"

# Database Configurations
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app

# Directly specify the SQLAlchemy URI to override dynamically composed URI
# SQLALCHEMY_DATABASE_URI="postgresql+asyncpg://postgres:postgres@localhost:5432/app"

# Security (JWT Access & Refresh Tokens)
# Generate cryptographically secure keys in production: 'openssl rand -hex 32'
JWT_SECRET_KEY="supersecretaccesskeyforfastapiproductionstarter123!"
JWT_REFRESH_SECRET_KEY="supersecretrefreshkeyforfastapiproductionstarter123!"
ALGORITHM="HS256"

# Token Expiry Durations
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080  # 7 days (60 * 24 * 7)
